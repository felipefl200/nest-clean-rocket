{
  "name": "nest-clean-rocket",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write .",
    "start": "nest start --exec 'node --env-file=.env'",
    "dev": "nest start --watch --exec 'node --env-file=.env'",
    "debug": "nest start --debug --watch --exec 'node --env-file=.env'",
    "prod": "node --env-file-if-exists=.env dist/main.js",
    "lint": "eslint . --fix",
    "test:db:up": "docker compose -f docker-compose.test.yml up -d --wait",
    "test:db:down": "docker compose -f docker-compose.test.yml down -v",
    "test:db:push": "node --env-file=.env.test ./node_modules/prisma/build/index.js db push --force-reset",
    "test:e2e": "node --env-file=.env.test ./node_modules/vitest/vitest.mjs run --config vitest.e2e.config.ts",
    "test:e2e:int": "npm run test:db:up && npm run test:db:push && npm run test:e2e",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:push": "prisma db push",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "prisma:format": "prisma format",
    "db:generate": "node --env-file=.env --run prisma:generate",
    "db:migrate": "node --env-file=.env --run prisma:migrate",
    "db:push": "node --env-file=.env --run prisma:push",
    "db:deploy": "node --env-file-if-exists=.env --run prisma:deploy",
    "db:studio": "node --env-file=.env --run prisma:studio",
    "db:format": "node --run prisma:format"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1088.0",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^10.0.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcrypt": "^6.0.0",
    "dayjs": "^1.11.21",
    "passport-jwt": "^4.0.1",
    "pg": "^8.22.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.5.0",
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@swc/core": "^1.15.43",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^4.17.17",
    "@types/multer": "^2.2.0",
    "@types/node": "^24.13.2",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.0",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "prettier": "^3.9.4",
    "prisma": "^7.8.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.3",
    "unplugin-swc": "^1.5.9",
    "vitest": "^4.1.9"
  }
}
