# ─── Ambiente ───────────────────────────────────────────────────────────────────
NODE_ENV="development"

# ─── PostgreSQL ──────────────────────────────────────────────────────────────────
POSTGRES_DB="nest_clean_rocket"
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="postgres"
POSTGRES_PORT="5432"

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/nest_clean_rocket"

# ─── Servidor ────────────────────────────────────────────────────────────────────
PORT="3001"

# ─── JWT (RS256) ─────────────────────────────────────────────────────────────────
# Gere os certificados com:
#   openssl genpkey -algorithm RSA -out ./certs/jwtRS256.key -pkeyopt rsa_keygen_bits:2048
#   openssl rsa -pubout -in ./certs/jwtRS256.key -out ./certs/jwtRS256.key.pub
JWT_PRIVATE_KEY_PATH="./certs/jwtRS256.key"
JWT_PUBLIC_KEY_PATH="./certs/jwtRS256.key.pub"
JWT_EXPIRES_IN="15m"

# ─── BCrypt ──────────────────────────────────────────────────────────────────────
# Valor entre 10 e 14. Padrão: 12.
BCRYPT_COST="12"
