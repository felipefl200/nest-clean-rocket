{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "types": [
            "node",
            "vitest/globals"
        ],
        "noEmit": true
    },
    "include": [
        "src/**/*.ts",
        "test/**/*.ts",
        "prisma.config.ts",
        "vitest.config.ts",
        "vitest.e2e.config.ts"
    ],
    "exclude": [
        "node_modules",
        "dist",
        "coverage"
    ]
}